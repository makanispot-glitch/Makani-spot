#!/bin/sh
# githooks/pre-commit — يحدّث الإصدار (version) في كل الملفات تلقائيًا قبل كل commit.
# يُفعَّل محليًا عبر: git config core.hooksPath githooks   (راجع docs/VERSIONING.md)
#
# القاعدة الذهبية: هذا الملف لازم ميوقفش أي commit أبدًا مهما حصل جوه bump-version.ps1.

ROOT="$(git rev-parse --show-toplevel)"

if ! command -v powershell.exe >/dev/null 2>&1; then
  echo ""
  echo "[!] pre-commit: powershell.exe not found on this machine — committing WITHOUT a version bump."
  echo "    Run ./bump-version.ps1 manually before deploying to Cloudflare."
  echo ""
  exit 0
fi

powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$ROOT/bump-version.ps1"
STATUS=$?

if [ "$STATUS" -ne 0 ]; then
  echo ""
  echo "[!] pre-commit: bump-version.ps1 failed (exit $STATUS) — committing WITHOUT a version bump."
  echo "    Run ./bump-version.ps1 manually and make sure it succeeds before the next deploy."
  echo ""
fi

exit 0
